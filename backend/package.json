{
  "name": "acme-salary-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build --workspace=@acme/shared && tsx watch src/server.ts",
    "build": "npm run build --workspace=@acme/shared && tsc",
    "start": "node dist/server.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:import": "tsx src/db/import-employees.ts",
    "db:generate-spreadsheet": "tsx scripts/generate-employee-spreadsheet.ts",
    "db:generate-compensation-spreadsheet": "tsx scripts/generate-compensation-spreadsheet.ts",
    "db:generate-fixtures": "tsx scripts/generate-fixtures.ts",
    "db:reset": "docker compose exec -T postgres psql -U acme -d acme_salary -c 'DROP SCHEMA public CASCADE; CREATE SCHEMA public;' && tsx src/db/migrate.ts && tsx src/db/seed.ts"
  },
  "dependencies": {
    "@acme/shared": "*",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.38.3",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "multer": "^2.2.0",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^3.2.6",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.17.0",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^3.2.4"
  }
}
