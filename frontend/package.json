{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NEXT_IGNORE_INCORRECT_LOCKFILE=1 next dev",
    "build": "npm run build --workspace=@acme/shared && NEXT_IGNORE_INCORRECT_LOCKFILE=1 next build",
    "start": "next start",
